---
const features = [
  {
    title: "AIピクセルレベル認識",
    description: "SegFormer AIが19種類の顔パーツをピクセル単位で識別。横顔・帽子・逆光でも正確に検出。従来の顔検出とは次元の異なる精度。",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" /></svg>`,
  },
  {
    title: "シネマグレード補正",
    description: "映画・CMの色調整で使われるLift/Gamma/Offsetの3段階制御を自動適用。画像の暗さに応じてパラメータを自動算出。",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M4.098 19.902a3.75 3.75 0 0 0 5.304 0l6.401-6.402M6.75 21A3.75 3.75 0 0 1 3 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 0 0 3.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008Z" /></svg>`,
  },
  {
    title: "背景完全保護",
    description: "補正マスク外のピクセルは元画像と数学的に同一。背景の色味・質感を1ビットも変えない精密な処理。",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>`,
  },
];
---

<section id="features" class="py-24 px-4 bg-surface-900/50">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">
      3つの技術的特長
    </h2>
    <p class="text-surface-400 text-center mb-16 text-lg">
      プロの現場で使われる技術を、完全自動で
    </p>

    <div class="grid md:grid-cols-3 gap-8">
      {features.map((feature) => (
        <div class="group p-6 rounded-2xl bg-surface-800/50 border border-surface-700/50 hover:border-brand-500/30 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-brand-500/10 text-brand-400 flex items-center justify-center mb-4 group-hover:bg-brand-500/20 transition-colors">
            <Fragment set:html={feature.icon} />
          </div>
          <h3 class="text-lg font-bold mb-3 text-surface-100">
            {feature.title}
          </h3>
          <p class="text-surface-400 text-sm leading-relaxed">
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
