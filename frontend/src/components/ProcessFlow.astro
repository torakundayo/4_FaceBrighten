---

<section id="process" class="py-24 px-4">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">
      処理フロー
    </h2>
    <p class="text-surface-400 text-center mb-16 text-lg">
      5つのステップで、プロのカラリストと同じ品質の補正を自動実行
    </p>

    <div class="relative">
      {/* Vertical connecting line */}
      <div
        class="absolute left-[31px] top-10 bottom-10 w-px hidden md:block"
        style="background: linear-gradient(to bottom, transparent, var(--color-brand-500) 15%, var(--color-brand-500) 85%, transparent);"
      >
      </div>

      <div class="space-y-6">
        {steps.map((step, i) => (
          <div class="relative flex gap-5 md:gap-6 group">
            {/* Icon circle */}
            <div class="relative z-10 flex-shrink-0 w-16 h-16 rounded-full bg-surface-800 border-2 border-surface-700 flex items-center justify-center text-brand-400 group-hover:border-brand-500 group-hover:bg-brand-500/10 group-hover:shadow-[0_0_20px_rgba(12,147,233,0.15)] transition-all duration-300">
              <Fragment set:html={step.icon} />
            </div>

            {/* Content card */}
            <div class="flex-1 bg-surface-800/30 border border-surface-700/40 rounded-xl p-5 group-hover:border-brand-500/20 group-hover:bg-surface-800/50 transition-all duration-300">
              <div class="flex items-baseline gap-3 mb-1.5">
                <span class="text-brand-400 font-mono text-xs font-semibold tracking-wider opacity-70">
                  STEP {step.number}
                </span>
                <h3 class="text-lg font-bold text-surface-100">
                  {step.title}
                </h3>
              </div>
              <p class="text-surface-400 text-sm leading-relaxed mb-2">
                {step.description}
              </p>
              <span class="inline-block text-xs font-mono text-brand-300/50 bg-brand-500/5 border border-brand-500/10 px-2.5 py-0.5 rounded-full">
                {step.tech}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
